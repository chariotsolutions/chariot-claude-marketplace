{
  "name": "chariot-spec-first-testing",
  "description": "Enforces spec-first testing discipline: test specs must be updated before test code can be modified. Supports Java, TypeScript, and Python.",
  "version": "1.0.0",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-test-spec.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/track-spec-edits.sh"
          }
        ]
      }
    ]
  }
}
